// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  output     = "../src/lib/generated/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  description String
  content     String?  @db.Text
  image       String // URL from Cloudinary
  category    String
  date        String // Display date (e.g. "16 Jun")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  image       String // URL from Cloudinary
  time        String // e.g. "11:00 AM - 05:00 PM"
  location    String // e.g. "Serena Hotel, Faisalabad"
  date        String // e.g. "15 March, 2025"
  dayLabel    String // e.g. "DAY 1"
  dayId       String // e.g. "day1"
  color       String? // e.g. "bg_green"
  textWhite   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
